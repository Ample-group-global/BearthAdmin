# ─── Dashboard Authentication ─────────────────────────────────────────────────
# Secret key for signing session tokens (use a long random string in production)
AUTH_SECRET=change-me-to-a-long-random-string

# Technical Admin credentials (full access: contract ops, whitelist, wallet)
TECH_ADMIN_USERNAME=tech_admin
TECH_ADMIN_PASSWORD=TechAdmin2024!

# Operations Staff credentials (read-only + whitelist add; no wallet needed)
OPS_ADMIN_USERNAME=ops_admin
OPS_ADMIN_PASSWORD=OpsAdmin2024!

# ─── Customer Store URL (used for QR codes on product pages) ──────────────────
# Set to your production store URL; QR codes on products link to /products/{sku}
NEXT_PUBLIC_STORE_URL=https://bearth.io

# ─── Contract Configuration ───────────────────────────────────────────────────
# Contract Configuration
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Privy Configuration (get from https://dashboard.privy.io/)
NEXT_PUBLIC_PRIVY_APP_ID=YOUR_PRIVY_APP_ID
NEXT_PUBLIC_PRIVY_APP_SECRET=YOUR_PRIVY_APP_SECRET

# WalletConnect Project ID (get from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# Test User Addresses
NEXT_PUBLIC_USER_ADDR1=0x...
NEXT_PUBLIC_USER_ADDR2=0x...
